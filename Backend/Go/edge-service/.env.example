# ================================================
# Go Edge Service - Environment Variables
# Copy this file to .env and fill in real values
# ================================================

# Server
PORT=9090

# PostgreSQL (REQUIRED)
POSTGRES_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/univent?sslmode=disable

# Redis (REQUIRED)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# Kafka (REQUIRED)
KAFKA_BROKERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=
KAFKA_PASSWORD=

# JWT secret (REQUIRED - must match Spring Boot)
JWT_SECRET=YOUR_JWT_SECRET_HEX_HERE

# Internal service URLs
SPRING_BOOT_URL=http://localhost:8080
PYTHON_AI_URL=http://localhost:8000

# Environment
ENVIRONMENT=development
INTERNAL_SHARED_SECRET=your_internal_service_token_here
ALLOWED_ORIGINS=http://localhost:3000
