# ================================================
# UNIVENT BACKEND - Environment Variables
# Copy this file to .env and fill in real values
# ================================================

# ─── Database ─────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/univent
DB_USERNAME=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_HEX_HERE
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ─── Email (Gmail SMTP) ──────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=YOUR_APP_PASSWORD_HERE

# ─── MinIO ────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=univent-id-cards

# ─── Encryption ──────────────────────────────────────
ENCRYPTION_SECRET=YOUR_ENCRYPTION_SECRET_HERE

# ─── Kafka ────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=
KAFKA_PASSWORD=

# AI Worker
AI_WORKER_URL=http://localhost:8000
INTERNAL_SHARED_SECRET=your_internal_service_token_here
ALLOWED_ORIGINS=http://localhost:3000

# ─── Server ──────────────────────────────────────────
SERVER_PORT=8080

# ─── Gemini AI (shared with Python service) ───────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
