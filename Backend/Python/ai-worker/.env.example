# ================================================
# Python AI Worker - Environment Variables
# Copy this file to .env and fill in real values
# ================================================

# Server
HOST=0.0.0.0
PORT=8000

# Gemini API (REQUIRED)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# PostgreSQL (REQUIRED)
POSTGRES_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/univent
POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_STATEMENT_TIMEOUT_MS=10000

# Qdrant Vector DB
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Kafka (REQUIRED)
KAFKA_BROKERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Internal service auth
INTERNAL_SHARED_SECRET=your_internal_service_token_here
ALLOWED_ORIGINS=http://localhost:3000
