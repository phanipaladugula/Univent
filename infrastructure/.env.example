# Univent Production Environment Template
# Do NOT commit real secrets here. Remove this comment when copying to .env

# Security
JWT_SECRET=your_32_byte_hex_string_here
ENCRYPTION_SECRET=your_different_32_byte_hex_string_here
INTERNAL_SHARED_SECRET=your_internal_service_token_here
APP_EMAIL_SALT_PEPPER=your_long_random_email_pepper_here
REDIS_PASSWORD=your_strong_redis_password_here
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# Database
POSTGRES_PASSWORD=your_strong_postgres_password

# External Services
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_strong_minio_password

# Monitoring
GF_SECURITY_ADMIN_PASSWORD=your_grafana_admin_password

# Email
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password
